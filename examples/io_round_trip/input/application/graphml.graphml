<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns">
  <key id="scenario" for="graph" attr.name="scenario" attr.type="string"/>
  <key id="source_format" for="graph" attr.name="source_format" attr.type="string"/>
  <key id="cpu" for="node" attr.name="cpu" attr.type="double"/>
  <key id="ram" for="node" attr.name="ram" attr.type="double"/>
  <key id="image" for="node" attr.name="image" attr.type="string"/>
  <key id="build" for="node" attr.name="build" attr.type="string"/>
  <key id="latency" for="edge" attr.name="latency" attr.type="double"/>
  <key id="bandwidth" for="edge" attr.name="bandwidth" attr.type="double"/>
  <graph id="vision-application-graphml" edgedefault="directed">
    <data key="scenario">io-round-trip</data>
    <data key="source_format">graphml</data>
    <node id="camera-gateway">
      <data key="cpu">1</data>
      <data key="ram">1</data>
      <data key="image">ghcr.io/eclypse/camera-gateway:latest</data>
    </node>
    <node id="inference">
      <data key="cpu">4</data>
      <data key="ram">6</data>
      <data key="image">ghcr.io/eclypse/inference:latest</data>
    </node>
    <node id="dashboard">
      <data key="cpu">1</data>
      <data key="ram">1</data>
      <data key="build">./dashboard</data>
    </node>
    <edge source="camera-gateway" target="inference">
      <data key="latency">8</data>
      <data key="bandwidth">80</data>
    </edge>
    <edge source="inference" target="dashboard">
      <data key="latency">5</data>
      <data key="bandwidth">40</data>
    </edge>
  </graph>
</graphml>
